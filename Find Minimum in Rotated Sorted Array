whenever there is rotated sorted array -> apply Binary search
Optimised Approach-
identify sorted half:-
if left half is sorted->ans=Math.min(ans,arr[low})
                        low=mid+1    // left half sorted ka left-most element hi minimum hoga , so, now jump on right half
if right half is sorted->ans=Math.min(ans,arr[mid})
                        high=mid-1;  // right half sorted ka left-most element hi minimum hoga , so, now jump on left half


// CODE
class Solution {
    public int findMin(int[] nums) {
        int n = nums.length;
        int low=0,high=n-1;
        int min = Integer.MAX_VALUE;
        while(low<=high){
            int mid = (low+high) / 2;
            // if left half is sorted
            if(nums[low]<=nums[mid]){
                min=Math.min(min,nums[low]);
                low=mid+1;     // eliminate left half
            }
            // if right half is sorted
            else{
                min=Math.min(min,nums[mid]);
                high=mid-1;    // eliminate right half
            }
        }
        return min;
    }
}
TC = O(logn)
SC = O(1)
